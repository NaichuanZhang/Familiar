# Database (required)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Bland AI voice calls
BLAND_API_KEY=
BLAND_AGENT_ID=
DEFAULT_PHONE_NUMBER=+12125551234

# App URL — required for Bland AI webhook callbacks
BASE_URL=https://your-app.vercel.app

# Webhook security — Bland AI sends this header to verify callbacks
BLAND_WEBHOOK_SECRET=

# Cron job authorization
CRON_SECRET=

# Senso AI knowledge base
SENSO_KEY=
