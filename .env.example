# Auth0 — create an app at https://manage.auth0.com
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.grandmacare.local

# Set these to your Vercel deployment URL in production
# Leave unset for local dev (defaults to localhost:8000)
AUTH0_CALLBACK_URL=https://your-app.vercel.app/auth/callback
AUTH0_LOGOUT_URL=https://your-app.vercel.app
